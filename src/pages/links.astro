---
import BaseLayout from "../layouts/BaseLayout.astro";
import IconEmail from "../assets/icons/iconEmail.svg";
import IconGithub from "../assets/icons/iconGithub.svg";
import IconX from "../assets/icons/iconX.svg";
import IconLinkedIn from "../assets/icons/iconLinkedIn.svg";
import IconVerify from "../assets/icons/iconVerify.svg";
---

<BaseLayout title="Links">
  <section class="links-stack" aria-labelledby="links-heading">
    <header class="links-stack__intro">
      <img class="links-stack__avatar" src="/favicon.png" alt="Second Realm icon" width="96" height="96" />
      <h1 id="links-heading">@secondrealm</h1>
      <p>curious, creative, &amp; ever-evolving &#x1F331;</p>
      <nav class="links-stack__social" aria-label="Social links">
        <a href="mailto:secondrealm@gmail.com" aria-label="Email"><IconEmail /></a>
        <a href="/verify" aria-label="Verify"><IconVerify /></a>
        <a href="https://github.com/secondrealm" aria-label="GitHub"><IconGithub /></a>
        <a href="https://x.com/secondrealm" aria-label="X"><IconX /></a>
        <a href="https://linkedin.com/in/secondrealm" aria-label="LinkedIn"><IconLinkedIn /></a>
      </nav>
    </header>

    <ul class="links-stack__list">
      <li><a class="links-stack__item" href="https://secondrealm.com">go to my website</a></li>
      <li><a class="links-stack__item" href="https://superrare.com/secondrealm">superrare</a></li>
      <li><a class="links-stack__item" href="https://legacy.secondrealm.com">crypto art</a></li>
      <li><a class="links-stack__item" href="https://catalog.seconcrealm.com">full art catalog (sheet)</a></li>
      <li><a class="links-stack__item" href="https://secondrealm.com/verify">trust, but verify</a></li>
    </ul>
  </section>
</BaseLayout>
